<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/wine_background" 
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardBackgroundColor="@color/wine_primary"
            app:cardCornerRadius="36dp"
            app:cardElevation="16dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/wine_accent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:src="@android:drawable/ic_btn_speak_now"
                app:tint="@color/text_muted" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AudioRouter"
            android:textColor="@color/text_light"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:layout_marginTop="16dp"/>
            
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="nic-cavalheiro"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/connectionCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        app:cardBackgroundColor="@color/wine_primary"
        app:cardCornerRadius="24dp"
        app:cardElevation="20dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="@color/wine_accent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_manage"
                    app:tint="@color/text_muted"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONFIGURAÇÃO DE CONEXÃO"
                    android:textColor="@color/text_muted"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:letterSpacing="0.08"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:boxBackgroundColor="@color/wine_surface"
                    app:boxStrokeColor="@color/wine_accent"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:hintTextColor="@color/text_muted"
                    app:startIconDrawable="@android:drawable/ic_menu_info_details"
                    app:startIconTint="@color/text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editIpAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Endereço IP do PC"
                        android:textColor="@color/text_light"
                        android:textSize="16sp"
                        android:fontFamily="monospace"
                        android:inputType="numberDecimal|text"
                        android:digits="0123456789."
                        android:paddingTop="18dp"
                        android:paddingBottom="18dp"
                        android:textCursorDrawable="@null"/>
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBuscarPc"
                    style="@style/Widget.MaterialComponents.Button.Icon"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginStart="12dp"
                    app:icon="@android:drawable/ic_menu_search"
                    app:iconTint="@color/text_light"
                    app:iconSize="28dp"
                    app:iconPadding="0dp"
                    app:iconGravity="textStart"
                    app:cornerRadius="16dp"
                    app:backgroundTint="@color/wine_accent"
                    app:elevation="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/statusCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/wine_primary"
        app:cardCornerRadius="24dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="@color/wine_accent"
        app:layout_constraintTop_toBottomOf="@id/connectionCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○ AGUARDANDO CONEXÃO"
                android:textColor="@color/status_disconnected"
                android:fontFamily="sans-serif-condensed-medium"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnIniciar"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="INICIAR TRANSMISSÃO"
            android:textSize="18sp"
            android:letterSpacing="0.05"
            android:textStyle="bold"
            app:icon="@android:drawable/ic_media_play"
            app:iconSize="32dp"
            app:iconGravity="textStart"
            app:cornerRadius="24dp"
            app:backgroundTint="@color/wine_accent"
            android:textColor="@color/text_light"
            app:elevation="12dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnParar"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="16dp"
            android:text="ENCERRAR SESSÃO"
            android:textSize="18sp"
            android:letterSpacing="0.05"
            android:textStyle="bold"
            app:icon="@android:drawable/ic_media_pause"
            app:iconSize="32dp"
            app:iconGravity="textStart"
            app:cornerRadius="24dp"
            app:strokeColor="@color/wine_accent"
            app:strokeWidth="3dp"
            android:textColor="@color/text_muted"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>